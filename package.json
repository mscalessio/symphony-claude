{
  "name": "symphony-claude",
  "version": "0.0.1",
  "description": "Long-running orchestration service that polls Linear for issues and runs Claude Code CLI sessions",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "symphony": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "liquidjs": "^10.25.0",
    "gray-matter": "^4.0.3",
    "zod": "^3.25.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "fastify": "^5.2.0",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
